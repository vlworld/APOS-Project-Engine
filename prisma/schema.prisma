generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── APOS Schema ──────────────────────────────────────────────────────────────
// Rollen- und Rechtestruktur aus OOS uebernommen, damit Nutzer mit demselben
// Mental-Model arbeiten und wir spaeter via zentrale Task-API ohne Rollen-
// Mapping andocken koennen.

// ─── Rollen-Konvention (role-Feld) ────────────────────────────────────────
//
//   EMPLOYEE   — Standard-Mitarbeiter
//   MANAGER    — Fuehrungskraft (erweiterte Sichtbarkeit, Team-Boards,
//                darf fremde PRIVATE-Objekte mit "Privat"-Badge sehen)
//   ADMIN      — Organisationsadministrator (darf alles im Org-Scope)
//   DEVELOPER  — Technischer Entwickler (sieht System-interne Ansichten;
//                Dev-PRIVATE-Objekte sind fuer niemanden sichtbar)

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String
  password      String?   // bcrypt-Hash, null wenn SSO
  role          String    @default("EMPLOYEE") // EMPLOYEE | MANAGER | ADMIN | DEVELOPER
  kuerzel       String?   // Kuerzel / Initialen (max 3 Zeichen)
  position      String?
  department    String?
  image         String?
  emailVerified DateTime?

  // Flags (aus OOS uebernommen, semantisch identisch)
  isExternal           Boolean @default(false)
  isDisabled           Boolean @default(false)
  hasOosAccess         Boolean @default(true)
  hasAposAccess        Boolean @default(true)
  mobileClockInAllowed Boolean @default(false)
  reasonRequiredOnShift Boolean @default(false)
  isReportRequired     Boolean @default(false)
  betaMode             Boolean @default(false)

  lastSeenAt DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Multi-Tenancy
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // Relationen
  managedProjects       Project[]            @relation("ProjectManager")
  projectMemberships    ProjectMember[]
  undoEntries           ScheduleUndoEntry[]
  meetingsLed           Meeting[]            @relation("MeetingLeader")
  meetingsScribed       Meeting[]            @relation("MeetingScribe")
  meetingParticipations MeetingParticipant[]
  responsibleItems      MeetingItem[]
  assignedTodos         Todo[]

  @@index([organizationId])
  @@index([role])
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String?  @unique
  logoUrl   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users            User[]
  projects         Project[]
  tradeCategories  TradeCategory[]
  holidays         Holiday[]
  customers        Customer[]
}

model Project {
  id             String    @id @default(cuid())
  name           String
  projectNumber  String    @unique
  description    String?
  status         String    @default("PLANNING") // PLANNING | ACTIVE | ON_HOLD | COMPLETED | ARCHIVED
  clientName     String?   // Legacy / Fallback, wenn kein verknüpfter Customer
  customerId     String?
  address        String?
  budget         Float?
  startDate               DateTime? // Projektstart (offiziell)
  endDate                 DateTime? // Geplantes Projektende
  plannedConstructionStart DateTime? // Geplanter Baustart
  plannedCommissioning    DateTime? // Geplante Inbetriebnahme
  deadline                DateTime? // Harte Deadline (z.B. Förderzusage, Netzzusage)
  dataRoomUrl             String?   // Interner Datenraum (Google Drive / SharePoint / etc.)
  customerDataRoomUrl     String?   // Optionaler Datenraum vom Kunden
  isSample       Boolean   @default(false) // Muster-Projekt, via Toggle einblendbar
  organizationId String
  managerId      String
  steeringCommitteeUserIds String[] @default([]) // User-IDs im Steuerkreis (zusätzlich zum Manager)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  bauherrCustomerId        String?
  landownerCustomerId      String?

  // Sichtbarkeit fuer andere Projektleiter (User mit role=MANAGER) in derselben Organisation.
  //   OPEN       = andere Manager koennen das Projekt sehen (Details lesen). Default.
  //   RESTRICTED = nur Manager + Mitglieder des Projekts sehen es.
  // ADMIN/DEVELOPER sehen immer alles; EMPLOYEES brauchen nach wie vor Membership.
  visibility            String  @default("OPEN") // OPEN | RESTRICTED
  allowEditByOthers     Boolean @default(false)  // Default: sehen ja, bearbeiten nein

  organization  Organization    @relation(fields: [organizationId], references: [id])
  manager       User            @relation("ProjectManager", fields: [managerId], references: [id])
  customer      Customer?       @relation("ProjectAuftraggeber", fields: [customerId], references: [id], onDelete: SetNull)
  bauherr       Customer?       @relation("ProjectBauherr", fields: [bauherrCustomerId], references: [id], onDelete: SetNull)
  landowner     Customer?       @relation("ProjectLandowner", fields: [landownerCustomerId], references: [id], onDelete: SetNull)
  scheduleItems ScheduleItem[]
  members       ProjectMember[]
  briefing      ProjectBriefing?
  meetings      Meeting[]
  todos         Todo[]

  @@index([organizationId])
  @@index([managerId])
  @@index([status])
  @@index([isSample])
  @@index([customerId])
  @@index([bauherrCustomerId])
  @@index([landownerCustomerId])
}

// ─── CRM ───────────────────────────────────────────────────────────────────

model Customer {
  id              String   @id @default(cuid())
  organizationId  String
  companyName     String
  legalForm       String?  // GmbH, UG, AG, e.V., Einzelunternehmen, ...
  street          String?
  zipCode         String?
  city            String?
  country         String?  @default("Deutschland")
  website         String?
  phone           String?
  email           String?
  taxId           String?  // Steuernummer
  vatId           String?  // USt-IdNr.
  classification  String   @default("STANDARD") // STANDARD | IMPORTANT | STRATEGIC | WATCH | BLOCKED
  notes           String?
  isSample        Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  organization      Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  contacts          CustomerContact[]
  projects          Project[]         @relation("ProjectAuftraggeber")
  bauherrProjects   Project[]         @relation("ProjectBauherr")
  landownerProjects Project[]         @relation("ProjectLandowner")

  @@index([organizationId])
  @@index([classification])
  @@index([isSample])
}

model CustomerContact {
  id         String   @id @default(cuid())
  customerId String
  firstName  String?
  lastName   String
  salutation String?  // Herr, Frau, Dr., Prof.
  role       String?  // CEO, Projektleiter, Einkauf, ...
  email      String?
  phone      String?
  mobile     String?
  isPrimary  Boolean  @default(false)
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
}

// ─── Bauzeitenplan / Gantt ─────────────────────────────────────────────────

model TradeCategory {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  color          String   // Tailwind-Token-Name (z.B. "blue", "emerald", "rose")
  orderIndex     Int      @default(0)
  isSample       Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization  Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  scheduleItems ScheduleItem[]

  @@unique([organizationId, name])
  @@index([organizationId])
  @@index([isSample])
}

model ScheduleItem {
  id              String   @id @default(cuid())
  projectId       String
  parentId        String?
  name            String
  description     String?
  startDate       DateTime
  endDate         DateTime
  bufferDays      Int      @default(0) // Puffer in Arbeitstagen nach endDate (optional, schraffiert dargestellt)
  deadline        DateTime? // Harte Deadline (optional) — z.B. Foerderzusage, Netzzusage. Mit rotem Flag im Gantt markiert.
  progress        Int      @default(0) // 0–100
  status          String   @default("OPEN") // OPEN | IN_PROGRESS | DONE
  tradeCategoryId String?
  isMilestone     Boolean  @default(false)
  isTimeRange     Boolean  @default(false) // Fuzzy Zeitraum (z.B. "Modullieferung KW 14-15") mit diskreten Events
  color           String?  // optionaler Override, Default = tradeCategory.color
  orderIndex      Int      @default(0)
  assignedToId    String?  // optionaler User-Bezug (für Personal-View)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  project       Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  parent        ScheduleItem?  @relation("ScheduleItemHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children      ScheduleItem[] @relation("ScheduleItemHierarchy")
  tradeCategory TradeCategory? @relation(fields: [tradeCategoryId], references: [id], onDelete: SetNull)

  dependenciesOut ScheduleDependency[] @relation("DependencyFrom")
  dependenciesIn  ScheduleDependency[] @relation("DependencyTo")
  events          ScheduleItemEvent[]

  @@index([projectId])
  @@index([parentId])
  @@index([tradeCategoryId])
  @@index([assignedToId])
  @@index([status])
}

// Diskretes Event innerhalb eines Zeitraum-Items (isTimeRange = true).
// z.B. "Modullieferung KW 14-15" hat Events: "Teillieferung 1 am 08.04"
// (SCHEDULED) und "Teillieferung 2 KW 15" (PLANNED).
model ScheduleItemEvent {
  id        String   @id @default(cuid())
  itemId    String
  date      DateTime // Exakter Tag
  label     String?  // z.B. "Teillieferung 1", "Modul-Container 2"
  status    String   @default("PLANNED") // PLANNED (geplant, noch zu terminieren) | SCHEDULED (abgestimmt/terminiert) | DONE (erledigt)
  orderIndex Int     @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  item ScheduleItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([itemId])
  @@index([date])
}

model ScheduleDependency {
  id        String   @id @default(cuid())
  fromId    String
  toId      String
  type      String   @default("FS") // FS | SS | FF
  lagDays   Int      @default(0)
  createdAt DateTime @default(now())

  from ScheduleItem @relation("DependencyFrom", fields: [fromId], references: [id], onDelete: Cascade)
  to   ScheduleItem @relation("DependencyTo",   fields: [toId],   references: [id], onDelete: Cascade)

  @@unique([fromId, toId, type])
  @@index([fromId])
  @@index([toId])
}

model Holiday {
  id             String   @id @default(cuid())
  organizationId String
  date           DateTime
  name           String
  isSample       Boolean  @default(false)
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, date])
  @@index([organizationId])
  @@index([isSample])
}

model ProjectMember {
  id        String   @id @default(cuid())
  projectId String
  userId    String
  role      String   @default("READ") // READ | WRITE
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId],    references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@index([projectId])
  @@index([userId])
}

model ScheduleUndoEntry {
  id          String   @id @default(cuid())
  userId      String
  projectId   String
  action      String   // "move" | "resize" | "delete" | "create" | "reorder" | "dep.add" | "dep.remove"
  beforeState Json     // vollständiger State-Snapshot vor der Aktion
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([projectId])
  @@index([createdAt])
}

// ─── Projektsteckbrief (Übergabeprotokoll) ─────────────────────────────────
// Pro Projekt genau ein Steckbrief (1:1). Strukturiertes Übergabedokument
// mit Grundinfos, BW-Daten, Technik, Abwicklung und einer Nächste-Schritte-
// Checkliste. Felder, die bereits am Project-Model hängen (z.B. Adresse,
// Projektnummer, Baustart), werden NICHT dupliziert.

model ProjectBriefing {
  id        String @id @default(cuid())
  projectId String @unique

  // Grundinformationen
  akquisiteur          String?
  groesseKwp           Float?
  verantwortlichkeit   String?
  prioritaet           String? // "A" | "B" | "C"
  richtlinie           String? // z.B. "4110"
  anlagentyp           String? // "Freifläche" | "Dach" | "Batterie"
  projektbeschreibung  String?
  vorhandeneUnterlagen String?

  // Betriebswirtschaftlich
  stakeholder        String?
  ansprechpartner    String?
  auftragsvolumenEur Float?
  bwMeilensteine     String?

  // Technisch
  netzgebiet         String?
  technischeAnnahmen String?
  monteurplanung     String?

  // Projektabwicklung
  herausforderungen      String?
  absehbareProbleme      String?
  informationsIntervall  String?
  ersteTodos             String?
  offeneTodosVorStart    String?
  erwartungenKunde       String?
  ausserordentlicheAbspr String?
  sonstigeAnmerkungen    String?

  // Übergabe-Checkliste als JSON:
  // Array<{ id: string; text: string; verantwortlich: string | null; done: boolean; doneAt?: string }>
  naechsteSchritte Json?

  // Meta
  version          String    @default("1.0")
  uebergebenAm     DateTime?
  uebergebenVonId  String?
  uebernommenVonId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

// ─── Protokolle / Meetings ─────────────────────────────────────────────────
// Strukturiertes Gesprächsprotokoll pro Projekt. Punkte (MeetingItem) sind
// keine Freitext-Blöcke, sondern einzelne Entitäten — so können sie später
// als ToDo übernommen oder in ein Folge-Protokoll kopiert werden.

model Meeting {
  id                String   @id @default(cuid())
  projectId         String

  // Kopfdaten (aus PDF-Vorlage)
  title             String    // Thema, z.B. "PV-Anlage"
  meetingDate       DateTime  // Datum des Termins
  durationMinutes   Int?      // Zeitspanne in Minuten
  location          String?   // Ort (z.B. "Teams", "Büro Ennepetal")
  area              String?   // Bereich (freies Feld)
  isInternal        Boolean   @default(true) // intern / extern

  // Verantwortlichkeiten
  leaderId          String?   // Leitung
  scribeId          String?   // Protokollant

  // Kette: Ein Protokoll kann auf einem Vorgänger aufbauen
  previousMeetingId String?

  // Freigabe-Workflow (optional — aus PDF: "Erarbeitet", "Geprüft", Rev.)
  preparedByText    String?
  approvedByText    String?
  approvedAt        DateTime?
  revisionNumber    Int       @default(0)

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  project           Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  leader            User?                @relation("MeetingLeader", fields: [leaderId], references: [id], onDelete: SetNull)
  scribe            User?                @relation("MeetingScribe", fields: [scribeId], references: [id], onDelete: SetNull)
  previousMeeting   Meeting?             @relation("MeetingChain", fields: [previousMeetingId], references: [id], onDelete: SetNull)
  nextMeetings      Meeting[]            @relation("MeetingChain")
  participants      MeetingParticipant[]
  items             MeetingItem[]
  sourceTodos       Todo[]               @relation("TodoFromMeeting")

  @@index([projectId])
  @@index([meetingDate])
  @@index([leaderId])
  @@index([scribeId])
  @@index([previousMeetingId])
}

model MeetingParticipant {
  id            String   @id @default(cuid())
  meetingId     String
  userId        String?  // APOS-User (strukturiert)
  externalName  String?  // Fallback für externe Personen ("Hr. Sprenger")
  roleText      String?  // z.B. "Geschäftsführung", "Monteur"
  orderIndex    Int      @default(0)

  meeting       Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  user          User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([meetingId])
  @@index([userId])
}

model MeetingItem {
  id                 String   @id @default(cuid())
  meetingId          String
  orderIndex         Int      @default(0)   // "Nr." in der PDF-Tabelle

  // Inhalt
  category           String?  // B (Beschluss) | E (Empfehlung) | F (Feststellung) | I (Info) | A (Arbeitsauftrag)
  title              String?  // Kurz-Titel (z.B. "Wechselrichter")
  description        String   // Haupttext

  // Zuständigkeit
  responsibleText    String?  // "SJM", "Vom Lehn" — Freitext (auch Firmen)
  responsibleUserId  String?  // optional strukturiert

  // Termin
  dueDate            DateTime?
  dueDateText        String?  // "KW 8", "Q1/23", "Ende Juli"

  status             String   @default("OPEN") // OPEN | IN_PROGRESS | DONE

  // Quelle: aus früherem Protokoll übernommen?
  copiedFromItemId   String?

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  meeting            Meeting       @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  responsibleUser    User?         @relation(fields: [responsibleUserId], references: [id], onDelete: SetNull)
  copiedFromItem     MeetingItem?  @relation("ItemCopy", fields: [copiedFromItemId], references: [id], onDelete: SetNull)
  copies             MeetingItem[] @relation("ItemCopy")
  sourceTodos        Todo[]        @relation("TodoFromItem")

  @@index([meetingId])
  @@index([status])
  @@index([responsibleUserId])
  @@index([copiedFromItemId])
}

// ─── ToDos ─────────────────────────────────────────────────────────────────
// Generisches ToDo-System. ToDos entstehen v.a. aus Protokoll-Punkten
// ("Übernehmen" aus MeetingItem), können aber auch direkt angelegt werden.
// Ein ToDo kann optional einem Arbeitspaket zugeordnet werden —
// workPackageId ist vorerst nur ein Placeholder-String, weil WP-Schema
// noch nicht existiert.

model Todo {
  id                  String    @id @default(cuid())
  projectId           String

  title               String
  description         String?
  assignedToId        String?   // strukturiert
  assignedToText      String?   // Freitext (extern)
  dueDate             DateTime?
  status              String    @default("OPEN") // OPEN | IN_PROGRESS | DONE

  // Quellen
  sourceMeetingItemId String?
  sourceMeetingId     String?   // denormalisiert für schnelle Projekt-Queries
  workPackageId       String?   // später: FK auf WorkPackage-Model

  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  project             Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignedTo          User?         @relation(fields: [assignedToId], references: [id], onDelete: SetNull)
  sourceMeetingItem   MeetingItem?  @relation("TodoFromItem", fields: [sourceMeetingItemId], references: [id], onDelete: SetNull)
  sourceMeeting       Meeting?      @relation("TodoFromMeeting", fields: [sourceMeetingId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([assignedToId])
  @@index([status])
  @@index([sourceMeetingItemId])
  @@index([sourceMeetingId])
}
